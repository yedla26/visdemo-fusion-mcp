# Copy this file to .env and fill in real values.
# NEVER commit the real .env file — it is already listed in .gitignore.

FUSION_BASE_URL=https://dabpqy.ds-fa.oraclepdemos.com
FUSION_USER=PPM_IMPL
FUSION_PASSWORD=replace-with-real-password
FUSION_MAX_ROWS=100
LOG_LEVEL=INFO

# Optional: direct DB connection for run_sql() tool (separate from FUSION_* REST creds above)
DB_HOST=replace-with-db-host
DB_PORT=1521
DB_SERVICE_NAME=replace-with-service-name
DB_USER=replace-with-db-user
DB_PASSWORD=replace-with-db-password

# GitHub push (use a Personal Access Token, NOT your account password —
# GitHub Settings > Developer settings > Personal access tokens > Fine-grained/Classic,
# scope: repo). Never your real GitHub login password here.
GITHUB_USERNAME=replace-with-github-username
GITHUB_TOKEN=replace-with-personal-access-token
